generator client {
  provider = "prisma-client"
  output   = "../generated/prisma-sqlite"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String    @unique
  phone        String?
  preferredLanguage String    @default("en")
  passwordHash String
  isVerified   Boolean   @default(false)
  role         String    @default("USER")
  status       String    @default("ACTIVE")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  blogs        Blog[]
  comments     Comment[]

  @@index([role])
  @@index([status])
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  blogs       Blog[]
}

model Blog {
  id                  Int       @id @default(autoincrement())
  title               String
  slug                String    @unique
  excerpt             String?
  content             String
  status              String    @default("DRAFT")
  language            String    @default("en")
  contentCategory     String    @default("GENERAL_WELLNESS")
  medicalReviewStatus String    @default("NOT_SUBMITTED")
  reviewedById        Int?
  reviewedAt          DateTime?
  reviewNotes         String?
  publishedAt         DateTime?
  archivedAt          DateTime?
  creatorId           Int
  categoryId          Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  creator             User      @relation(fields: [creatorId], references: [id])
  category            Category? @relation(fields: [categoryId], references: [id])
  comments            Comment[]
  media               Media[]

  @@index([status])
  @@index([language])
  @@index([contentCategory])
  @@index([medicalReviewStatus])
  @@index([reviewedAt])
  @@index([publishedAt])
  @@index([createdAt])
}

model Comment {
  id              Int       @id @default(autoincrement())
  blogId          Int
  userId          Int
  comment         String
  parentCommentId Int?
  createdAt       DateTime  @default(now())
  blog            Blog      @relation(fields: [blogId], references: [id])
  user            User      @relation(fields: [userId], references: [id])
  parentComment   Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies         Comment[] @relation("CommentReplies")
}

model Media {
  id         Int      @id @default(autoincrement())
  blogId     Int
  mediaUrl   String
  mediaType  String?
  altText    String?
  uploadedAt DateTime @default(now())
  blog       Blog     @relation(fields: [blogId], references: [id])
}
model DoctorProfile {
  id                 Int      @id @default(autoincrement())
  userId             Int?     @unique
  fullName           String
  email              String?
  phone              String?
  country            String?
  cityRegion         String?
  licenseNumber      String?
  specialty          String?
  languagesSpoken    String?
  yearsOfExperience  Int?
  bio                String?
  verificationStatus String   @default("PENDING")
  availabilityStatus String   @default("UNAVAILABLE")
  verifiedById       Int?
  verifiedAt         DateTime?
  rejectionReason    String?
  suspensionReason   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  facilityMemberships FacilityProfessional[]

  @@index([verificationStatus])
  @@index([specialty])
  @@index([createdAt])
}

model SymptomCheckLog {
  id                    Int      @id @default(autoincrement())
  userId                Int?
  language              String   @default("en")
  symptomsSummary       String
  aiResponseSummary     String?
  symptomCategory       String?
  riskLevel             String   @default("LOW")
  recommendedNextStep   String?
  escalationSuggested   Boolean  @default(false)
  status                String   @default("COMPLETED")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([riskLevel])
  @@index([language])
  @@index([status])
  @@index([escalationSuggested])
  @@index([createdAt])
}

model AiInteractionFlag {
  id                            Int       @id @default(autoincrement())
  symptomCheckLogId             Int?
  mentalHealthInteractionId      Int?
  userId                        Int?
  title                         String
  summary                       String?
  category                      String
  trigger                       String    @default("AUTOMATIC_RISK_RULE")
  priority                      String    @default("MEDIUM")
  status                        String    @default("OPEN")
  assignedReviewerId            Int?
  adminNotes                    String?
  reviewerNotes                 String?
  resolutionNotes               String?
  escalatedConsultationRequestId Int?
  resolvedAt                    DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  @@index([symptomCheckLogId])
  @@index([mentalHealthInteractionId])
  @@index([userId])
  @@index([assignedReviewerId])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([trigger])
  @@index([createdAt])
}

model ConsultationRequest {
  id                 Int      @id @default(autoincrement())
  userId             Int?
  assignedDoctorId   Int?
  reasonSummary      String
  preferredLanguage  String   @default("en")
  countryRegion      String?
  urgencyLevel       String   @default("LOW")
  requestedSpecialty String?
  status             String   @default("NEW")
  adminNotes         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([assignedDoctorId])
  @@index([status])
  @@index([urgencyLevel])
  @@index([preferredLanguage])
  @@index([requestedSpecialty])
  @@index([createdAt])
}

model SafetyReport {
  id              Int      @id @default(autoincrement())
  reporterUserId  Int?
  assignedAdminId Int?
  type            String
  title           String
  summary         String?
  priority        String   @default("MEDIUM")
  status          String   @default("OPEN")
  resolutionNotes String?
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([reporterUserId])
  @@index([assignedAdminId])
  @@index([type])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model SafetyReportActionHistory {
  id            Int      @id @default(autoincrement())
  reportId      Int
  actorAdminId  Int?
  actionType    String
  fromStatus    String?
  toStatus      String?
  fromPriority  String?
  toPriority    String?
  fromAdminId   Int?
  toAdminId     Int?
  note          String?
  createdAt     DateTime @default(now())

  @@index([reportId])
  @@index([actorAdminId])
  @@index([actionType])
  @@index([createdAt])
}


model MentalHealthInteraction {
  id                    Int      @id @default(autoincrement())
  userId                Int?
  language              String   @default("en")
  moodCategory          String   @default("GENERAL_SUPPORT")
  riskLevel             String   @default("LOW")
  interactionSummary    String
  aiResponseSummary     String?
  supportResourcesShown String?
  escalationSuggested   Boolean  @default(false)
  status                String   @default("COMPLETED")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([language])
  @@index([moodCategory])
  @@index([riskLevel])
  @@index([escalationSuggested])
  @@index([status])
  @@index([createdAt])
}

model MentalHealthResource {
  id          Int      @id @default(autoincrement())
  hotlineName String
  country     String
  phone       String?
  website     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([country])
  @@index([isActive])
  @@index([createdAt])
}


model AdminAuditLog {
  id          Int      @id @default(autoincrement())
  adminUserId Int?
  actionType  String
  targetType  String
  targetId    String
  oldValue    String?
  newValue    String?
  reason      String?
  createdAt   DateTime @default(now())

  @@index([adminUserId])
  @@index([actionType])
  @@index([targetType])
  @@index([targetId])
  @@index([createdAt])
}


model AdminSensitiveHealthAccessGrant {
  id          Int      @id @default(autoincrement())
  adminUserId Int
  targetType  String
  targetId    String
  reason      String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([adminUserId])
  @@index([targetType])
  @@index([targetId])
  @@index([expiresAt])
  @@index([createdAt])
}

model PlatformSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  updatedById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([updatedById])
  @@index([updatedAt])
}

model HealthResource {
  id          Int      @id @default(autoincrement())
  type        String
  name        String
  country     String
  region      String?
  phone       String?
  email       String?
  website     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([country])
  @@index([region])
  @@index([isActive])
  @@index([createdAt])
}

model Facility {
  id                 Int      @id @default(autoincrement())
  name               String
  type               String   @default("CLINIC")
  email              String?
  phone              String?
  website            String?
  country            String
  region             String?
  city               String?
  address            String?
  latitude           Float?
  longitude          Float?
  description        String?
  services           String?
  operatingHours     String?
  adminId            Int?
  verificationStatus String   @default("PENDING")
  verifiedById       Int?
  verifiedAt         DateTime?
  rejectionReason    String?
  suspensionReason   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  professionals      FacilityProfessional[]
  events             Event[]

  @@index([verificationStatus])
  @@index([country])
  @@index([type])
  @@index([createdAt])
}

model FacilityProfessional {
  id              Int      @id @default(autoincrement())
  facilityId      Int
  doctorProfileId Int
  role            String   @default("STAFF_DOCTOR")
  addedById       Int?
  status          String   @default("ACTIVE")
  addedAt         DateTime @default(now())
  facility        Facility @relation(fields: [facilityId], references: [id])
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id])

  @@unique([facilityId, doctorProfileId])
  @@index([facilityId])
  @@index([doctorProfileId])
  @@index([status])
}

model Event {
  id          Int       @id @default(autoincrement())
  facilityId  Int
  title       String
  description String?
  type        String    @default("HEALTH_TALK")
  startDate   DateTime
  endDate     DateTime?
  location    String?
  isPublic    Boolean   @default(true)
  status      String    @default("UPCOMING")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  facility    Facility  @relation(fields: [facilityId], references: [id])

  @@index([facilityId])
  @@index([status])
  @@index([startDate])
  @@index([type])
}

model Notification {
  id              Int       @id @default(autoincrement())
  recipientUserId Int
  type            String
  title           String
  message         String
  priority        String    @default("NORMAL")
  targetType      String?
  targetId        String?
  status          String    @default("UNREAD")
  readAt          DateTime?
  createdAt       DateTime  @default(now())

  @@index([recipientUserId])
  @@index([type])
  @@index([priority])
  @@index([status])
  @@index([targetType, targetId])
  @@index([createdAt])
}
