generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String    @unique
  phone        String?
  preferredLanguage String    @default("en")
  passwordHash String
  isVerified   Boolean   @default(false)
  role         String    @default("USER")
  status       String    @default("ACTIVE")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  blogs        Blog[]
  comments     Comment[]

  @@index([role])
  @@index([status])
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  blogs       Blog[]
}

model Blog {
  id         Int       @id @default(autoincrement())
  title      String
  slug       String    @unique
  content    String
  status     String    @default("draft")
  creatorId  Int
  categoryId Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  creator    User      @relation(fields: [creatorId], references: [id])
  category   Category? @relation(fields: [categoryId], references: [id])
  comments   Comment[]
  media      Media[]

  @@index([status])
  @@index([createdAt])
}

model Comment {
  id              Int       @id @default(autoincrement())
  blogId          Int
  userId          Int
  comment         String
  parentCommentId Int?
  createdAt       DateTime  @default(now())
  blog            Blog      @relation(fields: [blogId], references: [id])
  user            User      @relation(fields: [userId], references: [id])
  parentComment   Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies         Comment[] @relation("CommentReplies")
}

model Media {
  id         Int      @id @default(autoincrement())
  blogId     Int
  mediaUrl   String
  mediaType  String?
  altText    String?
  uploadedAt DateTime @default(now())
  blog       Blog     @relation(fields: [blogId], references: [id])
}
model DoctorProfile {
  id                 Int      @id @default(autoincrement())
  userId             Int?     @unique
  fullName           String
  email              String?
  phone              String?
  country            String?
  cityRegion         String?
  licenseNumber      String?
  specialty          String?
  languagesSpoken    String?
  yearsOfExperience  Int?
  bio                String?
  verificationStatus String   @default("PENDING")
  availabilityStatus String   @default("UNAVAILABLE")
  verifiedById       Int?
  verifiedAt         DateTime?
  rejectionReason    String?
  suspensionReason   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([verificationStatus])
  @@index([specialty])
  @@index([createdAt])
}

model SymptomCheckLog {
  id                    Int      @id @default(autoincrement())
  userId                Int?
  language              String   @default("en")
  symptomsSummary       String
  aiResponseSummary     String?
  symptomCategory       String?
  riskLevel             String   @default("LOW")
  recommendedNextStep   String?
  escalationSuggested   Boolean  @default(false)
  status                String   @default("COMPLETED")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([riskLevel])
  @@index([language])
  @@index([createdAt])
}

model AiInteractionFlag {
  id                 Int      @id @default(autoincrement())
  symptomCheckLogId  Int?
  userId             Int?
  title              String
  summary            String?
  category           String
  priority           String   @default("MEDIUM")
  status             String   @default("OPEN")
  assignedReviewerId Int?
  reviewerNotes      String?
  resolutionNotes    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([createdAt])
}

model ConsultationRequest {
  id                 Int      @id @default(autoincrement())
  userId             Int?
  assignedDoctorId   Int?
  reasonSummary      String
  preferredLanguage  String   @default("en")
  countryRegion      String?
  urgencyLevel       String   @default("NORMAL")
  requestedSpecialty String?
  status             String   @default("NEW")
  adminNotes         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status])
  @@index([urgencyLevel])
  @@index([preferredLanguage])
  @@index([createdAt])
}

model SafetyReport {
  id              Int      @id @default(autoincrement())
  reporterUserId  Int?
  assignedAdminId Int?
  type            String
  title           String
  summary         String?
  priority        String   @default("MEDIUM")
  status          String   @default("OPEN")
  resolutionNotes String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

